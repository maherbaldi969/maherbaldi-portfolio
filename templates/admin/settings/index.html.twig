{% extends 'base.html.twig' %}

{% block title %}Admin Settings{% endblock %}

{% block body %}
<div class="admin-page">

    <aside class="admin-sidebar">
        <div class="admin-sidebar-top">
            <a href="{{ path('app_home') }}" class="brand admin-brand">
                <span class="brand-logo"><span class="brand-mark"></span></span>
                <span class="brand-text">MB<span class="dot">.</span></span>
            </a>
            <p class="admin-panel-label">Portfolio Admin</p>
        </div>

        <nav class="admin-menu">
            <a href="{{ path('app_admin_dashboard') }}">Dashboard</a>
            <a href="{{ path('app_admin_projects') }}">Projects</a>
            <a href="{{ path('app_admin_skills') }}">Skills</a>
            <a href="{{ path('app_admin_experience') }}">Experience</a>
            <a href="{{ path('app_admin_education') }}">Education</a>
            <a href="{{ path('app_admin_messages') }}">Messages</a>
            <a href="{{ path('app_admin_settings') }}" class="active">Settings</a>
        </nav>

        <div class="admin-sidebar-bottom">
            <a href="{{ path('app_home') }}" class="admin-link-secondary">View Website</a>
            <a href="{{ path('app_logout') }}" class="admin-logout-btn">Logout</a>
        </div>
    </aside>

    <main class="admin-main">
        <div class="admin-page-head">
            <div>
                <p class="admin-topbar-label">SITE SETTINGS</p>
                <h1 class="admin-page-title">Settings</h1>
            </div>
        </div>

        {% for message in app.flashes('success') %}
            <div class="admin-flash-success">{{ message }}</div>
        {% endfor %}

        <section class="admin-panel-card">
            {{ form_start(form, {
                attr: {
                    class: 'admin-form-grid',
                    enctype: 'multipart/form-data'
                }
            }) }}

                <div class="admin-form-group admin-form-group-full">
                    {{ form_label(form.githubUrl) }}
                    {{ form_widget(form.githubUrl, {'attr': {'class': 'admin-input', 'placeholder': 'https://github.com/your-profile'}}) }}
                </div>

                <div class="admin-form-group admin-form-group-full">
                    {{ form_label(form.linkedinUrl) }}
                    {{ form_widget(form.linkedinUrl, {'attr': {'class': 'admin-input', 'placeholder': 'https://linkedin.com/in/your-profile'}}) }}
                </div>

                <div class="admin-form-group admin-form-group-full">
                    {{ form_label(form.contactEmail) }}
                    {{ form_widget(form.contactEmail, {'attr': {'class': 'admin-input', 'placeholder': 'you@example.com'}}) }}
                </div>

                <div class="admin-form-group admin-form-group-full">
                    {{ form_label(form.cvFile) }}
                    {{ form_widget(form.cvFile, {'attr': {'class': 'admin-file-input'}}) }}
                    <small class="admin-help-text">Upload un nouveau CV PDF depuis ton PC.</small>
                </div>

                {% if settings.cvFilePath %}
                    <div class="admin-form-group admin-form-group-full">
                        <label>Current CV</label>
                        <div class="admin-current-file-box">
                            <a href="{{ asset(settings.cvFilePath) }}" target="_blank" class="admin-primary-btn">
                                View Current CV
                            </a>

                            <form method="post" action="{{ path('app_admin_settings_delete_cv') }}" onsubmit="return confirm('Supprimer le CV actuel ?');">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete_cv') }}">
                                <button type="submit" class="admin-small-btn admin-small-btn-danger">Delete CV</button>
                            </form>
                        </div>
                    </div>
                {% endif %}

                <div class="admin-form-actions">
                    <button type="submit" class="admin-primary-btn">Save Settings</button>
                </div>

            {{ form_end(form) }}
        </section>
    </main>

</div>
{% endblock %}