{% extends 'base.html.twig' %}

{% block title %}Admin Account{% endblock %}

{% block body %}
<div class="admin-page">

    <aside class="admin-sidebar">
        <div class="admin-sidebar-top">
            <a href="{{ path('app_home') }}" class="brand admin-brand">
                <span class="brand-logo"><span class="brand-mark"></span></span>
                <span class="brand-text">MB<span class="dot">.</span></span>
            </a>
            <p class="admin-panel-label">Portfolio Admin</p>
        </div>

        <nav class="admin-menu">
            <a href="{{ path('app_admin_dashboard') }}">Dashboard</a>
            <a href="{{ path('app_admin_projects') }}">Projects</a>
            <a href="{{ path('app_admin_skills') }}">Skills</a>
            <a href="{{ path('app_admin_experience') }}">Experience</a>
            <a href="{{ path('app_admin_education') }}">Education</a>
            <a href="{{ path('app_admin_messages') }}">Messages</a>
            <a href="{{ path('app_admin_account') }}" class="active">Account</a>
            <a href="{{ path('app_admin_settings') }}">Settings</a>
        </nav>

        <div class="admin-sidebar-bottom">
            <a href="{{ path('app_home') }}" class="admin-link-secondary">View Website</a>
            <a href="{{ path('app_logout') }}" class="admin-logout-btn">Logout</a>
        </div>
    </aside>

    <main class="admin-main">
        <div class="admin-page-head">
            <div>
                <p class="admin-topbar-label">ACCOUNT SETTINGS</p>
                <h1 class="admin-page-title">Manage Account</h1>
            </div>
        </div>

        {% for message in app.flashes('success') %}
            <div class="admin-flash-success">{{ message }}</div>
        {% endfor %}

        {% for message in app.flashes('error') %}
            <div class="admin-flash-error">{{ message }}</div>
        {% endfor %}

        <section class="admin-panel-card">
            {{ form_start(form, {'attr': {'class': 'admin-form-grid'}}) }}

                <div class="admin-form-group admin-form-group-full">
                    {{ form_label(form.email) }}
                    {{ form_widget(form.email, {'attr': {'class': 'admin-input', 'placeholder': 'admin@example.com'}}) }}
                    {{ form_errors(form.email) }}
                </div>

                <div class="admin-form-group admin-form-group-full">
                    <h3 class="admin-section-subtitle">Change Password</h3>
                </div>

 <div class="admin-form-group admin-form-group-full">
    {{ form_label(form.currentPassword, 'Current Password') }}
    <div class="admin-password-wrap">
        {{ form_widget(form.currentPassword, {
            'attr': {
                'class': 'admin-input admin-password-input',
                'autocomplete': 'current-password'
            }
        }) }}
        <button type="button" class="admin-password-toggle" data-toggle-password>
            Show
        </button>
    </div>
    {{ form_errors(form.currentPassword) }}
</div>

<div class="admin-form-group">
    {{ form_label(form.newPassword, 'New Password') }}
    <div class="admin-password-wrap">
        {{ form_widget(form.newPassword, {
            'attr': {
                'class': 'admin-input admin-password-input',
                'autocomplete': 'new-password'
            }
        }) }}
        <button type="button" class="admin-password-toggle" data-toggle-password>
            Show
        </button>
    </div>
    {{ form_errors(form.newPassword) }}
</div>

<div class="admin-form-group">
    {{ form_label(form.confirmPassword, 'Confirm New Password') }}
    <div class="admin-password-wrap">
        {{ form_widget(form.confirmPassword, {
            'attr': {
                'class': 'admin-input admin-password-input',
                'autocomplete': 'new-password'
            }
        }) }}
        <button type="button" class="admin-password-toggle" data-toggle-password>
            Show
        </button>
    </div>
    {{ form_errors(form.confirmPassword) }}
</div>

                <div class="admin-form-actions">
                    <button type="submit" class="admin-primary-btn">Save Account</button>
                </div>

            {{ form_end(form) }}
        </section>
    </main>

</div>
<script>
document.addEventListener('DOMContentLoaded', function () {
    const toggleButtons = document.querySelectorAll('[data-toggle-password]');

    toggleButtons.forEach(function (button) {
        button.addEventListener('click', function () {
            const wrapper = button.closest('.admin-password-wrap');
            const input = wrapper.querySelector('input');

            if (!input) {
                return;
            }

            if (input.type === 'password') {
                input.type = 'text';
                button.textContent = 'Hide';
            } else {
                input.type = 'password';
                button.textContent = 'Show';
            }
        });
    });
});
</script>
{% endblock %}