{% extends 'base.html.twig' %}

{% block title %}Login | Maher Baldi{% endblock %}

{% block body %}
<div class="login-page">

    <header class="site-header login-header">
        <div class="container header-inner">
            <a href="{{ path('app_home') }}" class="brand">
                <span class="brand-logo">
                    <span class="brand-mark"></span>
                </span>
                <span class="brand-text">MB<span class="dot">.</span></span>
            </a>

            <nav class="desktop-nav">
                <a href="{{ path('app_home') }}#about">About</a>
                <a href="{{ path('app_home') }}#skills">Skills</a>
                <a href="{{ path('app_home') }}#projects">Projects</a>
                <a href="{{ path('app_home') }}#experience">Experience</a>
                <a href="{{ path('app_home') }}#contact">Contact</a>
            </nav>

            <a href="{{ asset('files/maher-baldi-cv.pdf') }}" class="btn btn-primary header-btn" download>
                DOWNLOAD CV
            </a>
        </div>
    </header>

    <section class="login-section">
        <div class="container login-grid">

            <div class="login-left">
                <p class="login-label">ADMIN ACCESS</p>

                <h1 class="login-title">
                    Welcome
                    <span>back</span>
                </h1>

                <p class="login-description">
                    Secure access to manage your portfolio content, projects,
                    experience, skills, and messages.
                </p>

                <div class="login-feature-list">
                    <div class="login-feature-item">Manage projects and portfolio sections</div>
                    <div class="login-feature-item">Update skills and experience</div>
                    <div class="login-feature-item">Review contact messages securely</div>
                </div>
            </div>

            <div class="login-right">
                <div class="login-card">

                    <div class="login-card-top">
                        <div class="terminal-dots">
                            <span class="dot red"></span>
                            <span class="dot yellow"></span>
                            <span class="dot green"></span>
                        </div>
                        <span class="login-card-title">admin@portfolio:~</span>
                    </div>

                    <div class="login-card-body">
                        <h2>Admin Login</h2>
                        <p>Sign in to access the portfolio dashboard.</p>

                        {% if error %}
                            <div class="login-alert">
                                Email or password is incorrect.
                            </div>
                        {% endif %}

                        <form method="post" class="login-form">
                            <div class="form-group">
                                <label for="inputEmail">EMAIL</label>
                                <input
                                    type="email"
                                    value="{{ last_username }}"
                                    name="email"
                                    id="inputEmail"
                                    class="form-control"
                                    placeholder="admin@portfolio.com"
                                    autocomplete="email"
                                    required
                                    autofocus
                                >
                            </div>

                            <div class="form-group">
                                <label for="inputPassword">PASSWORD</label>
                                <input
                                    type="password"
                                    name="password"
                                    id="inputPassword"
                                    class="form-control"
                                    placeholder="Enter your password"
                                    autocomplete="current-password"
                                    required
                                >
                            </div>

                            <input type="hidden" name="_csrf_token"
                                   value="{{ csrf_token('authenticate') }}"
                            >

                            <button class="login-submit-btn" type="submit">
                                Sign In
                            </button>
                        </form>

                        <div class="login-footer-note">
                            Protected portfolio administration area.
                        </div>
                    </div>

                </div>
            </div>

        </div>

        <div class="login-glow login-glow-1"></div>
        <div class="login-glow login-glow-2"></div>
    </section>

</div>
{% endblock %}