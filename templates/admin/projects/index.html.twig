{% extends 'base.html.twig' %}

{% block title %}Admin Projects{% endblock %}

{% block body %}
<div class="admin-page">

    <aside class="admin-sidebar">
        <div class="admin-sidebar-top">
            <a href="{{ path('app_home') }}" class="brand admin-brand">
                <span class="brand-logo"><span class="brand-mark"></span></span>
                <span class="brand-text">MB<span class="dot">.</span></span>
            </a>

            <p class="admin-panel-label">Portfolio Admin</p>
        </div>

        <nav class="admin-menu">
            <a href="{{ path('app_admin_dashboard') }}">Dashboard</a>
            <a href="{{ path('app_admin_projects') }}" class="active">Projects</a>
            <a href="#">Skills</a>
            <a href="#">Experience</a>
            <a href="#">Messages</a>
            <a href="#">Settings</a>
        </nav>

        <div class="admin-sidebar-bottom">
            <a href="{{ path('app_home') }}" class="admin-link-secondary">View Website</a>
            <a href="{{ path('app_logout') }}" class="admin-logout-btn">Logout</a>
        </div>
    </aside>

    <main class="admin-main">
        <div class="admin-page-head">
            <div>
                <p class="admin-topbar-label">PROJECT MANAGEMENT</p>
                <h1 class="admin-page-title">Manage Projects</h1>
            </div>

            <a href="{{ path('app_admin_projects_new') }}" class="admin-primary-btn">+ Add Project</a>
        </div>

        {% for message in app.flashes('success') %}
            <div class="admin-flash-success">{{ message }}</div>
        {% endfor %}

        <section class="admin-panel-card">
            <div class="admin-table-wrap">
                <table class="admin-table">
                    <thead>
                        <tr>
                            <th>Title</th>
                            <th>Slug</th>
                            <th>Status</th>
                            <th>Updated</th>
                            <th style="width: 320px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                    {% for project in projects %}
                        <tr>
                            <td>{{ project.title }}</td>
                            <td>{{ project.slug }}</td>
                            <td>
                                {% if project.isPublished %}
                                    <span class="status-pill">Published</span>
                                {% else %}
                                    <span class="status-pill status-pill-muted">Draft</span>
                                {% endif %}
                            </td>
                            <td>{{ project.updatedAt ? project.updatedAt|date('d/m/Y H:i') : '-' }}</td>
                            <td>
                                <div class="admin-actions-inline">
                                    <a href="{{ path('app_admin_projects_edit', {id: project.id}) }}" class="admin-small-btn">Edit</a>

                                    <form method="post" action="{{ path('app_admin_projects_toggle_publish', {id: project.id}) }}">
                                        <input type="hidden" name="_token" value="{{ csrf_token('toggle_publish_' ~ project.id) }}">
                                        <button type="submit" class="admin-small-btn admin-small-btn-alt">
                                            {{ project.isPublished ? 'Unpublish' : 'Publish' }}
                                        </button>
                                    </form>

                                    <form method="post" action="{{ path('app_admin_projects_delete', {id: project.id}) }}" onsubmit="return confirm('Supprimer ce projet ?');">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete_project_' ~ project.id) }}">
                                        <button type="submit" class="admin-small-btn admin-small-btn-danger">Delete</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="5">Aucun projet pour le moment.</td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </section>
    </main>

</div>
{% endblock %}
