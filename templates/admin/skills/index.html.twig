{% extends 'base.html.twig' %}

{% block title %}Admin Skills{% endblock %}

{% block body %}
<div class="admin-page">

    <aside class="admin-sidebar">
        <div class="admin-sidebar-top">
            <a href="{{ path('app_home') }}" class="brand admin-brand">
                <span class="brand-logo"><span class="brand-mark"></span></span>
                <span class="brand-text">MB<span class="dot">.</span></span>
            </a>
            <p class="admin-panel-label">Portfolio Admin</p>
        </div>

        <nav class="admin-menu">
            <a href="{{ path('app_admin_dashboard') }}">Dashboard</a>
            <a href="{{ path('app_admin_projects') }}">Projects</a>
            <a href="{{ path('app_admin_skills') }}" class="active">Skills</a>
            <a href="#">Experience</a>
            <a href="{{ path('app_admin_messages') }}">Messages</a>
            <a href="#">Settings</a>
        </nav>

        <div class="admin-sidebar-bottom">
            <a href="{{ path('app_home') }}" class="admin-link-secondary">View Website</a>
            <a href="{{ path('app_logout') }}" class="admin-logout-btn">Logout</a>
        </div>
    </aside>

    <main class="admin-main">
        <div class="admin-page-head">
            <div>
                <p class="admin-topbar-label">SKILLS MANAGEMENT</p>
                <h1 class="admin-page-title">Skills</h1>
            </div>

            <a href="{{ path('app_admin_skills_new') }}" class="admin-primary-btn">+ Add Skill</a>
        </div>

        {% for message in app.flashes('success') %}
            <div class="admin-flash-success">{{ message }}</div>
        {% endfor %}

        <section class="admin-panel-card">
            <div class="admin-table-wrap">
                <table class="admin-table">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Category</th>
                            <th>Level</th>
                            <th>Order</th>
                            <th>Status</th>
                            <th>Bars</th>
                            <th>Tags</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                    {% for skill in skills %}
                        <tr>
                            <td>{{ skill.name }}</td>
                            <td>{{ skill.category }}</td>
                            <td>{{ skill.level is not null ? skill.level ~ '%' : '-' }}</td>
                            <td>{{ skill.displayOrder }}</td>
                            <td>
                                {% if skill.isPublished %}
                                    <span class="status-pill">Published</span>
                                {% else %}
                                    <span class="status-pill status-pill-muted">Draft</span>
                                {% endif %}
                            </td>
                            <td>{{ skill.showInBars ? 'Yes' : 'No' }}</td>
                            <td>{{ skill.showInTags ? 'Yes' : 'No' }}</td>
                            <td>
                                <div class="admin-actions-inline">
                                    <a href="{{ path('app_admin_skills_edit', {id: skill.id}) }}" class="admin-small-btn">Edit</a>

                                    <form method="post" action="{{ path('app_admin_skills_toggle_publish', {id: skill.id}) }}">
                                        <input type="hidden" name="_token" value="{{ csrf_token('toggle_skill_' ~ skill.id) }}">
                                        <button type="submit" class="admin-small-btn admin-small-btn-alt">
                                            {{ skill.isPublished ? 'Unpublish' : 'Publish' }}
                                        </button>
                                    </form>

                                    <form method="post" action="{{ path('app_admin_skills_delete', {id: skill.id}) }}" onsubmit="return confirm('Supprimer cette compétence ?');">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete_skill_' ~ skill.id) }}">
                                        <button type="submit" class="admin-small-btn admin-small-btn-danger">Delete</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="8">Aucune compétence pour le moment.</td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </section>
    </main>

</div>
{% endblock %}