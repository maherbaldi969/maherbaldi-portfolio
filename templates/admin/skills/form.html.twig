{% extends 'base.html.twig' %}

{% block title %}{{ pageTitle }}{% endblock %}

{% block body %}
<div class="admin-page">

    <aside class="admin-sidebar">
        <div class="admin-sidebar-top">
            <a href="{{ path('app_home') }}" class="brand admin-brand">
                <span class="brand-logo"><span class="brand-mark"></span></span>
                <span class="brand-text">MB<span class="dot">.</span></span>
            </a>
            <p class="admin-panel-label">Portfolio Admin</p>
        </div>

        <nav class="admin-menu">
            <a href="{{ path('app_admin_dashboard') }}">Dashboard</a>
            <a href="{{ path('app_admin_projects') }}">Projects</a>
            <a href="{{ path('app_admin_skills') }}" class="active">Skills</a>
            <a href="#">Experience</a>
            <a href="{{ path('app_admin_messages') }}">Messages</a>
            <a href="#">Settings</a>
        </nav>

        <div class="admin-sidebar-bottom">
            <a href="{{ path('app_home') }}" class="admin-link-secondary">View Website</a>
            <a href="{{ path('app_logout') }}" class="admin-logout-btn">Logout</a>
        </div>
    </aside>

    <main class="admin-main">
        <div class="admin-page-head">
            <div>
                <p class="admin-topbar-label">SKILL FORM</p>
                <h1 class="admin-page-title">{{ pageTitle }}</h1>
            </div>

            <a href="{{ path('app_admin_skills') }}" class="admin-link-secondary admin-link-inline">← Back</a>
        </div>

        <section class="admin-panel-card">
            {{ form_start(form, {'attr': {'class': 'admin-form-grid'}}) }}

                <div class="admin-form-group">
                    {{ form_label(form.name) }}
                    {{ form_widget(form.name, {'attr': {'class': 'admin-input'}}) }}
                </div>

                <div class="admin-form-group">
                    {{ form_label(form.category) }}
                    {{ form_widget(form.category, {'attr': {'class': 'admin-input'}}) }}
                </div>

                <div class="admin-form-group">
                    {{ form_label(form.level) }}
                    {{ form_widget(form.level, {'attr': {'class': 'admin-input'}}) }}
                </div>

                <div class="admin-form-group">
                    {{ form_label(form.displayOrder) }}
                    {{ form_widget(form.displayOrder, {'attr': {'class': 'admin-input'}}) }}
                </div>

                <div class="admin-form-group admin-form-checkbox">
                    {{ form_widget(form.isPublished) }}
                    {{ form_label(form.isPublished) }}
                </div>

                <div class="admin-form-group admin-form-checkbox">
                    {{ form_widget(form.showInBars) }}
                    {{ form_label(form.showInBars) }}
                </div>

                <div class="admin-form-group admin-form-checkbox">
                    {{ form_widget(form.showInTags) }}
                    {{ form_label(form.showInTags) }}
                </div>

                <div class="admin-form-actions">
                    <button type="submit" class="admin-primary-btn">Save Skill</button>
                </div>

            {{ form_end(form) }}
        </section>
    </main>

</div>
{% endblock %}