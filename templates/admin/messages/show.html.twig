{% extends 'base.html.twig' %}

{% block title %}View Message{% endblock %}

{% block body %}
<div class="admin-page">

    <aside class="admin-sidebar">
        <div class="admin-sidebar-top">
            <a href="{{ path('app_home') }}" class="brand admin-brand">
                <span class="brand-logo"><span class="brand-mark"></span></span>
                <span class="brand-text">MB<span class="dot">.</span></span>
            </a>
            <p class="admin-panel-label">Portfolio Admin</p>
        </div>

        <nav class="admin-menu">
            <a href="{{ path('app_admin_dashboard') }}">Dashboard</a>
            <a href="{{ path('app_admin_projects') }}">Projects</a>
            <a href="#">Skills</a>
            <a href="#">Experience</a>
            <a href="{{ path('app_admin_messages') }}" class="active">Messages</a>
            <a href="#">Settings</a>
        </nav>

        <div class="admin-sidebar-bottom">
            <a href="{{ path('app_home') }}" class="admin-link-secondary">View Website</a>
            <a href="{{ path('app_logout') }}" class="admin-logout-btn">Logout</a>
        </div>
    </aside>

    <main class="admin-main">
        <div class="admin-page-head">
            <div>
                <p class="admin-topbar-label">MESSAGE DETAIL</p>
                <h1 class="admin-page-title">View Message</h1>
            </div>

            <a href="{{ path('app_admin_messages') }}" class="admin-link-secondary admin-link-inline">← Back</a>
        </div>

        <section class="admin-panel-card">
            <div class="admin-info-list">
                <div class="admin-info-item">
                    <span>Name</span>
                    <strong>{{ messageItem.fullName }}</strong>
                </div>

                <div class="admin-info-item">
                    <span>Email</span>
                    <strong>{{ messageItem.email }}</strong>
                </div>

                <div class="admin-info-item">
                    <span>Subject</span>
                    <strong>{{ messageItem.subject ?: '-' }}</strong>
                </div>

                <div class="admin-info-item">
                    <span>Date</span>
                    <strong>{{ messageItem.createdAt|date('d/m/Y H:i') }}</strong>
                </div>
            </div>

            <div class="admin-message-box">
                {{ messageItem.message|nl2br }}
            </div>

            <div class="admin-form-actions" style="margin-top: 20px;">
                <a href="mailto:{{ messageItem.email }}?subject=Re: {{ messageItem.subject ?: 'Your message' }}" class="admin-primary-btn">
                    Reply by Email
                </a>
            </div>
        </section>
    </main>

</div>
{% endblock %}