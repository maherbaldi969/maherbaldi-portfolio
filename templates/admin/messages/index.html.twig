{% extends 'base.html.twig' %}

{% block title %}Admin Messages{% endblock %}

{% block body %}
<div class="admin-page">

    <aside class="admin-sidebar">
        <div class="admin-sidebar-top">
            <a href="{{ path('app_home') }}" class="brand admin-brand">
                <span class="brand-logo"><span class="brand-mark"></span></span>
                <span class="brand-text">MB<span class="dot">.</span></span>
            </a>
            <p class="admin-panel-label">Portfolio Admin</p>
        </div>

        <nav class="admin-menu">
            <a href="{{ path('app_admin_dashboard') }}">Dashboard</a>
            <a href="{{ path('app_admin_projects') }}">Projects</a>
            <a href="#">Skills</a>
            <a href="#">Experience</a>
            <a href="{{ path('app_admin_messages') }}" class="active">Messages</a>
            <a href="#">Settings</a>
        </nav>

        <div class="admin-sidebar-bottom">
            <a href="{{ path('app_home') }}" class="admin-link-secondary">View Website</a>
            <a href="{{ path('app_logout') }}" class="admin-logout-btn">Logout</a>
        </div>
    </aside>

    <main class="admin-main">
        <div class="admin-page-head">
            <div>
                <p class="admin-topbar-label">CONTACT MESSAGES</p>
                <h1 class="admin-page-title">Messages</h1>
            </div>
        </div>

        {% for message in app.flashes('success') %}
            <div class="admin-flash-success">{{ message }}</div>
        {% endfor %}

        <section class="admin-panel-card">
            <div class="admin-table-wrap">
                <table class="admin-table">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Subject</th>
                            <th>Status</th>
                            <th>Date</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                    {% for item in messages %}
                        <tr>
                            <td>{{ item.fullName }}</td>
                            <td>{{ item.email }}</td>
                            <td>{{ item.subject ?: '-' }}</td>
                            <td>
                                {% if item.isRead %}
                                    <span class="status-pill">Read</span>
                                {% else %}
                                    <span class="status-pill status-pill-muted">Unread</span>
                                {% endif %}
                            </td>
                            <td>{{ item.createdAt|date('d/m/Y H:i') }}</td>
                            <td>
                                <div class="admin-actions-inline">
                                    <a href="{{ path('app_admin_messages_show', {id: item.id}) }}" class="admin-small-btn">View</a>

                                    <form method="post" action="{{ path('app_admin_messages_delete', {id: item.id}) }}" onsubmit="return confirm('Supprimer ce message ?');">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete_message_' ~ item.id) }}">
                                        <button type="submit" class="admin-small-btn admin-small-btn-danger">Delete</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="6">Aucun message pour le moment.</td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </section>
    </main>

</div>
{% endblock %}