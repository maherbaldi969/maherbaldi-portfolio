{% extends 'base.html.twig' %}

{% block title %}Admin Dashboard | Maher Baldi{% endblock %}

{% block body %}
<div class="admin-page">

    <aside class="admin-sidebar">
        <div class="admin-sidebar-top">
            <a href="{{ path('app_home') }}" class="brand admin-brand">
                <span class="brand-logo">
                    <span class="brand-mark"></span>
                </span>
                <span class="brand-text">MB<span class="dot">.</span></span>
            </a>

            <p class="admin-panel-label">Portfolio Admin</p>

            <nav class="admin-menu">
                <a href="{{ path('app_admin_dashboard') }}" class="active">Dashboard</a>
                <a href="{{ path('app_admin_projects') }}">Projects</a>
               <a href="{{ path('app_admin_skills') }}">Skills</a>
               <a href="{{ path('app_admin_experience') }}">Experience</a>
               <a href="{{ path('app_admin_education') }}">Education</a>
                <a href="{{ path('app_admin_messages') }}">Messages</a>
               <a href="{{ path('app_admin_settings') }}">Settings</a>
            </nav>
        </div>

        <div class="admin-sidebar-bottom">
            <a href="{{ path('app_home') }}" class="admin-link-secondary">View Website</a>
            <a href="{{ path('app_logout') }}" class="admin-logout-btn">Logout</a>
        </div>
    </aside>

    <main class="admin-main">
        <header class="admin-topbar">
            <div>
                <p class="admin-topbar-label">WELCOME BACK</p>
                <h1>Dashboard Overview</h1>
            </div>

            <div class="admin-user-box">
                <div class="admin-user-avatar">
                    {{ adminName|slice(0, 1)|upper }}
                </div>
                <div>
                    <strong>{{ adminName }}</strong>
                    <p>{{ adminEmail }}</p>
                </div>
            </div>
        </header>

        <section class="admin-stats-grid">
            <article class="admin-stat-card">
                <p>Total Projects</p>
                <h2>3</h2>
                <span>Published portfolio projects</span>
            </article>

            <article class="admin-stat-card">
                <p>Total Skills</p>
                <h2>16</h2>
                <span>Frontend, backend & tools</span>
            </article>

            <article class="admin-stat-card">
                <p>Experiences</p>
                <h2>2</h2>
                <span>Professional experience entries</span>
            </article>

            <article class="admin-stat-card">
                <p>Messages</p>
                <h2>0</h2>
                <span>Unread contact requests</span>
            </article>
        </section>

        <section class="admin-content-grid">
            <div class="admin-panel-card">
                <div class="admin-panel-head">
                    <h3>Quick Actions</h3>
                </div>

                <div class="admin-action-grid">
                    <a href="#" class="admin-action-card">
                        <strong>Add Project</strong>
                        <span>Create a new portfolio project</span>
                    </a>

                    <a href="#" class="admin-action-card">
                        <strong>Edit Skills</strong>
                        <span>Update technologies and levels</span>
                    </a>

                    <a href="#" class="admin-action-card">
                        <strong>Manage Experience</strong>
                        <span>Edit work history and roles</span>
                    </a>

                    <a href="#" class="admin-action-card">
                        <strong>Open Messages</strong>
                        <span>Review contact form submissions</span>
                    </a>
                </div>
            </div>

            <div class="admin-panel-card">
                <div class="admin-panel-head">
                    <h3>Admin Info</h3>
                </div>

                <div class="admin-info-list">
                    <div class="admin-info-item">
                        <span>Name</span>
                        <strong>{{ adminName }}</strong>
                    </div>

                    <div class="admin-info-item">
                        <span>Email</span>
                        <strong>{{ adminEmail }}</strong>
                    </div>

                    <div class="admin-info-item">
                        <span>Status</span>
                        <strong>Authenticated</strong>
                    </div>

                    <div class="admin-info-item">
                        <span>Role</span>
                        <strong>ROLE_ADMIN</strong>
                    </div>
                </div>
            </div>
        </section>

        <section class="admin-panel-card">
            <div class="admin-panel-head">
                <h3>Portfolio Management</h3>
            </div>

            <div class="admin-table-wrap">
                <table class="admin-table">
                    <thead>
                        <tr>
                            <th>Section</th>
                            <th>Status</th>
                            <th>Last Update</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>Home Hero</td>
                            <td><span class="status-pill">Active</span></td>
                            <td>Today</td>
                            <td><a href="#">Manage</a></td>
                        </tr>
                        <tr>
                            <td>Projects</td>
                            <td><span class="status-pill">Active</span></td>
                            <td>Today</td>
                            <td><a href="#">Manage</a></td>
                        </tr>
                        <tr>
                            <td>Experience</td>
                            <td><span class="status-pill">Active</span></td>
                            <td>Today</td>
                            <td><a href="#">Manage</a></td>
                        </tr>
                        <tr>
                            <td>Contact</td>
                            <td><span class="status-pill">Active</span></td>
                            <td>Today</td>
                            <td><a href="#">Manage</a></td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </section>
    </main>
</div>
{% endblock %}