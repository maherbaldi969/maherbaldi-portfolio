{% extends 'base.html.twig' %}

{% block title %}{{ pageTitle }}{% endblock %}

{% block body %}
<div class="admin-page">

    <aside class="admin-sidebar">
        <div class="admin-sidebar-top">
            <a href="{{ path('app_home') }}" class="brand admin-brand">
                <span class="brand-logo"><span class="brand-mark"></span></span>
                <span class="brand-text">MB<span class="dot">.</span></span>
            </a>
            <p class="admin-panel-label">Portfolio Admin</p>
        </div>

        <nav class="admin-menu">
            <a href="{{ path('app_admin_dashboard') }}">Dashboard</a>
            <a href="{{ path('app_admin_projects') }}">Projects</a>
            <a href="{{ path('app_admin_skills') }}">Skills</a>
            <a href="{{ path('app_admin_experience') }}" class="active">Experience</a>
            <a href="{{ path('app_admin_messages') }}">Messages</a>
            <a href="#">Settings</a>
        </nav>

        <div class="admin-sidebar-bottom">
            <a href="{{ path('app_home') }}" class="admin-link-secondary">View Website</a>
            <a href="{{ path('app_logout') }}" class="admin-logout-btn">Logout</a>
        </div>
    </aside>

    <main class="admin-main">
        <div class="admin-page-head">
            <div>
                <p class="admin-topbar-label">EXPERIENCE FORM</p>
                <h1 class="admin-page-title">{{ pageTitle }}</h1>
            </div>

            <a href="{{ path('app_admin_experience') }}" class="admin-link-secondary admin-link-inline">← Back</a>
        </div>

        <section class="admin-panel-card">
            {{ form_start(form, {'attr': {'class': 'admin-form-grid'}}) }}

                <div class="admin-form-group">
                    {{ form_label(form.jobTitle) }}
                    {{ form_widget(form.jobTitle, {'attr': {'class': 'admin-input'}}) }}
                </div>

                <div class="admin-form-group">
                    {{ form_label(form.companyName) }}
                    {{ form_widget(form.companyName, {'attr': {'class': 'admin-input'}}) }}
                </div>

                <div class="admin-form-group">
                    {{ form_label(form.employmentType) }}
                    {{ form_widget(form.employmentType, {'attr': {'class': 'admin-input'}}) }}
                </div>

                <div class="admin-form-group">
                    {{ form_label(form.locationLabel) }}
                    {{ form_widget(form.locationLabel, {'attr': {'class': 'admin-input'}}) }}
                </div>

                <div class="admin-form-group">
                    {{ form_label(form.startLabel) }}
                    {{ form_widget(form.startLabel, {'attr': {'class': 'admin-input'}}) }}
                </div>

                <div class="admin-form-group">
                    {{ form_label(form.endLabel) }}
                    {{ form_widget(form.endLabel, {'attr': {'class': 'admin-input'}}) }}
                </div>

                <div class="admin-form-group">
                    {{ form_label(form.displayOrder) }}
                    {{ form_widget(form.displayOrder, {'attr': {'class': 'admin-input'}}) }}
                </div>

                <div class="admin-form-group admin-form-group-full">
                    {{ form_label(form.summary) }}
                    {{ form_widget(form.summary, {'attr': {'class': 'admin-textarea'}}) }}
                </div>

                <div class="admin-form-group admin-form-group-full">
                    {{ form_label(form.achievementsText) }}
                    {{ form_widget(form.achievementsText, {'attr': {'class': 'admin-textarea', 'placeholder': 'Achievement 1\nAchievement 2\nAchievement 3'}}) }}
                    <small class="admin-help-text">Une ligne = un point</small>
                </div>

                <div class="admin-form-group admin-form-group-full">
                    {{ form_label(form.technologiesText) }}
                    {{ form_widget(form.technologiesText, {'attr': {'class': 'admin-textarea', 'placeholder': 'Symfony\nAngular\nPHP\nMySQL'}}) }}
                    <small class="admin-help-text">Une ligne = une technologie</small>
                </div>

                <div class="admin-form-group admin-form-checkbox">
                    {{ form_widget(form.isFeatured) }}
                    {{ form_label(form.isFeatured) }}
                </div>

                <div class="admin-form-group admin-form-checkbox">
                    {{ form_widget(form.isPublished) }}
                    {{ form_label(form.isPublished) }}
                </div>

                <div class="admin-form-actions">
                    <button type="submit" class="admin-primary-btn">Save Experience</button>
                </div>

            {{ form_end(form) }}
        </section>
    </main>

</div>
{% endblock %}