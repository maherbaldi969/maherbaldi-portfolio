{% extends 'base.html.twig' %}

{% block title %}{{ pageTitle }}{% endblock %}

{% block body %}
<div class="admin-page">

    <aside class="admin-sidebar">
        <div class="admin-sidebar-top">
            <a href="{{ path('app_home') }}" class="brand admin-brand">
                <span class="brand-logo"><span class="brand-mark"></span></span>
                <span class="brand-text">MB<span class="dot">.</span></span>
            </a>

            <p class="admin-panel-label">Portfolio Admin</p>
        </div>

        <nav class="admin-menu">
            <a href="{{ path('app_admin_dashboard') }}">Dashboard</a>
            <a href="{{ path('app_admin_projects') }}" class="active">Projects</a>
            <a href="#">Skills</a>
            <a href="#">Experience</a>
            <a href="#">Messages</a>
            <a href="#">Settings</a>
        </nav>

        <div class="admin-sidebar-bottom">
            <a href="{{ path('app_home') }}" class="admin-link-secondary">View Website</a>
            <a href="{{ path('app_logout') }}" class="admin-logout-btn">Logout</a>
        </div>
    </aside>

    <main class="admin-main">
        <div class="admin-page-head">
            <div>
                <p class="admin-topbar-label">PROJECT FORM</p>
                <h1 class="admin-page-title">{{ pageTitle }}</h1>
            </div>

            <a href="{{ path('app_admin_projects') }}" class="admin-link-secondary admin-link-inline">← Back</a>
        </div>

        <section class="admin-panel-card">
            {{ form_start(form, {'attr': {'class': 'admin-form-grid'}}) }}

                <div class="admin-form-group">
                    {{ form_label(form.title) }}
                    {{ form_widget(form.title, {'attr': {'class': 'admin-input'}}) }}
                </div>

                <div class="admin-form-group">
                    {{ form_label(form.slug) }}
                    {{ form_widget(form.slug, {'attr': {'class': 'admin-input'}}) }}
                </div>

                <div class="admin-form-group">
                    {{ form_label(form.shortDescription) }}
                    {{ form_widget(form.shortDescription, {'attr': {'class': 'admin-input'}}) }}
                </div>

                <div class="admin-form-group">
                    {{ form_label(form.imagePath) }}
                    {{ form_widget(form.imagePath, {'attr': {'class': 'admin-input', 'placeholder': 'images/project1.png'}}) }}
                </div>

                <div class="admin-form-group">
                    {{ form_label(form.githubUrl) }}
                    {{ form_widget(form.githubUrl, {'attr': {'class': 'admin-input'}}) }}
                </div>

                <div class="admin-form-group">
                    {{ form_label(form.demoUrl) }}
                    {{ form_widget(form.demoUrl, {'attr': {'class': 'admin-input'}}) }}
                </div>

                <div class="admin-form-group admin-form-group-full">
                    {{ form_label(form.fullDescription) }}
                    {{ form_widget(form.fullDescription, {'attr': {'class': 'admin-textarea'}}) }}
                </div>

                <div class="admin-form-group admin-form-group-full">
                    {{ form_label(form.technologiesText) }}
                    {{ form_widget(form.technologiesText, {'attr': {'class': 'admin-textarea', 'placeholder': 'Symfony\nMySQL\nTwig\nPHP'}}) }}
                    <small class="admin-help-text">Une technologie par ligne</small>
                </div>

                <div class="admin-form-group admin-form-group-full">
                    {{ form_label(form.featuresText) }}
                    {{ form_widget(form.featuresText, {'attr': {'class': 'admin-textarea', 'placeholder': 'Admin Dashboard\nOrder Management\nResponsive Design'}}) }}
                    <small class="admin-help-text">Une feature par ligne</small>
                </div>

                <div class="admin-form-group admin-form-checkbox">
                    {{ form_widget(form.isPublished) }}
                    {{ form_label(form.isPublished) }}
                </div>

                <div class="admin-form-actions">
                    <button type="submit" class="admin-primary-btn">Save Project</button>
                </div>

            {{ form_end(form) }}
        </section>
    </main>

</div>
{% endblock %}