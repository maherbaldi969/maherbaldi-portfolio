{# templates/partials/_about.html.twig #}

<!-- ABOUT -->
<section id="about" class="about-section">
    <div class="container about-wrapper">

        <div class="about-top">
            <div class="about-left-intro">
                <p class="section-label">ABOUT ME</p>

                <h2 class="about-title">
                    Crafting digital
                    <span>experiences</span>
                    from Tunisia.
                </h2>
            </div>

            <div class="about-right-intro">
                <p>
                    I'm a software developer from <strong>Tunisia</strong> with hands-on experience building
                    full-stack web applications. My expertise spans backend systems with Symfony,
                    dynamic frontends with Angular, and enterprise ERP customization with Odoo.
                </p>
