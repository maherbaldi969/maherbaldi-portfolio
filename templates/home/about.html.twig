        <div class="about-content-grid">

            <div class="about-left-column">
                <div class="about-image-card">
                    <img src="{{ asset('images/image_portfilo1.png') }}" alt="Maher Baldi workspace">
                </div>

                <div class="stats-grid">
                    <div class="stat-card">
                        <h3>3+</h3>
                        <p>YEARS EXPERIENCE</p>
                    </div>
                    <div class="stat-card">
                        <h3>10+</h3>
                        <p>PROJECTS SHIPPED</p>
                    </div>
                    <div class="stat-card">
                        <h3>3</h3>
                        <p>CORE FRAMEWORKS</p>
                    </div>
                    <div class="stat-card">
                        <h3>100%</h3>
                        <p>REMOTE READY</p>
                    </div>
                </div>
            </div>

            {# ── Skills inclus dans la colonne droite ── #}
            {% include 'home/skills.html.twig' %}

        </div>
    </div>
