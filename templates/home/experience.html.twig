{# templates/partials/_experience.html.twig #}

<!-- EXPERIENCE -->
<section id="experience" class="experience-section">
    <div class="container experience-wrapper">

        <div class="experience-top">
            <div class="experience-heading">
                <p class="section-label section-label-dark">EXPERIENCE</p>
                <h2 class="experience-title">
                    Where I've
                    <span>worked</span>
                </h2>
            </div>
            <div class="experience-intro">
                <p>
                    Real-world experience building production systems
                    for clients across Tunisia.
                </p>
            </div>
        </div>

        <div class="experience-list">

            <!-- Experience 1 -->
            <article class="experience-card experience-card-active">
                <div class="experience-left">
                    <h3>Odoo Developer</h3>
                    <h4>ERP Solutions Studio</h4>
                    <span class="experience-badge">Full-time</span>
                    <div class="experience-meta">
                        <p>🗓 2024 — Present</p>
                        <p>📍 Tunisia (Remote)</p>
                    </div>
                </div>
                <div class="experience-right">
                    <p class="experience-summary">
                        Custom Odoo module development and ERP system configuration for Tunisian businesses.
                        Delivered tailored workflows for inventory, HR, and accounting modules.
                    </p>
                    <ul class="experience-points">
                        <li>Built 5+ custom Odoo modules from scratch</li>
                        <li>Integrated external REST APIs with Odoo backend</li>
                        <li>Optimized SQL queries reducing report load time by 40%</li>
                        <li>Trained client teams on custom ERP workflows</li>
                    </ul>
                    <div class="experience-stack">
                        <span>Odoo</span>
                        <span>Python</span>
                        <span>PostgreSQL</span>
                        <span>XML</span>
                        <span>REST API</span>
                    </div>
                </div>
            </article>

            <!-- Experience 2 -->
            <article class="experience-card">
                <div class="experience-left">
                    <h3>Full Stack Developer</h3>
                    <h4>Freelance / Self-employed</h4>
                    <span class="experience-badge">Freelance</span>
                    <div class="experience-meta">
                        <p>🗓 2022 — 2024</p>
                        <p>📍 Tunisia</p>
                    </div>
                </div>
                <div class="experience-right">
                    <p class="experience-summary">
                        Designed and built complete web applications for clients across e-commerce,
                        healthcare, and service industries using Symfony and Angular.
                    </p>
                    <ul class="experience-points">
                        <li>Delivered Tunisian Pastry e-commerce platform end-to-end</li>
                        <li>Built Hijama clinic appointment booking system</li>
                        <li>Developed REST APIs consumed by Angular frontends</li>
                        <li>Maintained 100% on-time delivery across all projects</li>
                    </ul>
                    <div class="experience-stack">
                        <span>Symfony</span>
                        <span>Angular</span>
                        <span>PHP</span>
                        <span>MySQL</span>
                        <span>Bootstrap</span>
                    </div>
                </div>
            </article>

            <!-- Education -->
            <article class="education-card">
                <div class="education-icon">
                    <span>✦</span>
                </div>
                <div class="education-content">
                    <h3>Bachelor's in Computer Science</h3>
                    <p>University of Tunisia · Graduated 2022</p>
                </div>
            </article>

        </div>
    </div>
</section>
