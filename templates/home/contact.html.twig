{# templates/partials/_contact.html.twig #}

<!-- CONTACT -->
<section id="contact" class="contact-section">
    <div class="container contact-wrapper">

        <div class="contact-heading">
            <p class="section-label">GET IN TOUCH</p>
            <h2 class="contact-title">
                Let's work <span>together</span>
            </h2>
            <p class="contact-subtitle">
                Have a project in mind or looking for a developer? I'm open to freelance
                work and full-time opportunities.
            </p>
        </div>

        <div class="contact-grid">

            <!-- LEFT -->
            <div class="contact-left">

                <div class="contact-info-list">
                    <div class="contact-info-item">
                        <div class="contact-icon-box">⌖</div>
                        <div>
                            <h4>LOCATION</h4>
                            <p>Tunisia</p>
                        </div>
                    </div>
                    <div class="contact-info-item">
                        <div class="contact-icon-box">✉</div>
                        <div>
                            <h4>EMAIL</h4>
                            <p>maherbaldi.dev@gmail.com</p>
                        </div>
                    </div>
                    <div class="contact-info-item">
                        <div class="contact-icon-box">in</div>
                        <div>
                            <h4>LINKEDIN</h4>
                            <p>linkedin.com/in/maherbaldi</p>
                        </div>
                    </div>
                    <div class="contact-info-item">
                        <div class="contact-icon-box">⌘</div>
                        <div>
                            <h4>GITHUB</h4>
                            <p>github.com/maherbaldi</p>
                        </div>
                    </div>
                </div>

                <div class="availability-card">
                    <div class="availability-head">
                        <span class="availability-dot"></span>
                        <h3>Currently Available</h3>
                    </div>
                    <p>
                        I'm actively looking for new opportunities — full-time roles and freelance projects.
                        Response time: usually within 24 hours.
                    </p>
                    <div class="availability-tags">
                        <span>Full-time</span>
                        <span>Freelance</span>
                        <span>Remote</span>
                        <span>On-site (Tunisia)</span>
                    </div>
                </div>

            </div>

            <!-- RIGHT -->
            <div class="contact-right">
                <form class="contact-form" action="#" method="post">
                    <div class="contact-form-row">
                        <div class="form-group">
                            <label for="name">NAME</label>
                            <input id="name" name="name" type="text" placeholder="Your full name">
                        </div>
                        <div class="form-group">
                            <label for="email">EMAIL</label>
                            <input id="email" name="email" type="email" placeholder="your@email.com">
                        </div>
                    </div>
                    <div class="form-group">
                        <label for="message">MESSAGE</label>
                        <textarea id="message" name="message" rows="6" placeholder="Tell me about your project or opportunity..."></textarea>
                    </div>
                    <button type="submit" class="contact-submit-btn">
                        <span>✈</span>
                        SEND MESSAGE
                    </button>
                    <p class="contact-direct-email">
                        Or email me directly at
                        <a href="mailto:maherbaldi.dev@gmail.com">maherbaldi.dev@gmail.com</a>
                    </p>
                </form>
            </div>

        </div>
    </div>
</section>
