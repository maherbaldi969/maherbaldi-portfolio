{% extends 'base.html.twig' %}

{% block title %}Maher Baldi | Portfolio{% endblock %}

{% block body %}
<div class="portfolio-page">

    <!-- HEADER -->
    <header class="site-header">
        <div class="container header-inner">
            <a href="#" class="brand">
                <img src="{{ asset('images/Background (2).png') }}" alt="Logo" class="brand-logo-image">
                <span class="brand-text">MB<span class="dot">.</span></span>
            </a>

            <nav class="desktop-nav">
                <a href="#about">About</a>
                <a href="#skills">Skills</a>
                <a href="#projects">Projects</a>
                <a href="#experience">Experience</a>
                <a href="#contact">Contact</a>
            </nav>

            <div class="mobile-menu-container">
                <button class="mobile-menu-toggle" aria-label="Toggle mobile menu">
                    <span></span>
                    <span></span>
                    <span></span>
                </button>
                <nav class="mobile-menu">
                    <a href="#about">About</a>
                    <a href="#skills">Skills</a>
                    <a href="#projects">Projects</a>
                    <a href="#experience">Experience</a>
                    <a href="#contact">Contact</a>
                </nav>
            </div>

            <a href="{{ asset('files/maher-baldi-cv.pdf') }}" class="btn btn-primary header-btn" download>
                DOWNLOAD CV
            </a>
        </div>
    </header>

    <!-- HERO -->
    <section class="hero-section hero-section--cinematic">
        <div class="container hero-grid hero-grid--cinematic">

            <!-- GAUCHE : texte -->
            <div class="hero-left">

                <div class="hero-left-inner">
                    <div class="hero-text-col">
                        <p class="availability">AVAILABLE FOR HIRE · TUNISIA</p>

                        <h1 class="hero-title">
                            <span class="first-name">Maher</span>
                            <span class="last-name">Baldi</span>
                        </h1>

                        <div class="hero-role">
                            <span>Full Stack Developer</span>
                            <span class="separator">·</span>
                            <span>Symfony</span>
                            <span class="separator">·</span>
                            <span>Angular</span>
                            <span class="separator">·</span>
                            <span>Odoo</span>
                        </div>

                        <p class="hero-description">
                            Passionate software developer specializing in modern web applications using Symfony,
                            Angular, and Odoo. I build scalable, secure, and high-performance systems.
                        </p>
                    </div>
                </div>

                <div class="hero-actions">
                    <a href="#projects" class="btn btn-primary btn-large">
                        <span class="icon">⌘</span>
                        VIEW PROJECTS
                    </a>
                    <a href="{{ siteSettings and siteSettings.cvFilePath ? asset(siteSettings.cvFilePath) : '#' }}"
                       class="btn btn-outline btn-large"
                       {% if siteSettings and siteSettings.cvFilePath %}download{% endif %}>
                        <span class="icon">↓</span>
                        DOWNLOAD CV
                    </a>
                </div>

                <div class="hero-secondary">
                    <a href="#contact" class="btn btn-outline contact-btn">
                        <span class="icon">✉</span>
                        CONTACT ME
                    </a>
                </div>

                <div class="social-row">
                    <span class="line"></span>

                    <a href="{{ siteSettings and siteSettings.githubUrl ? siteSettings.githubUrl : '#' }}" target="_blank" aria-label="GitHub">
                        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61-.546-1.385-1.335-1.755-1.335-1.755-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
                        </svg>
                    </a>

                    <a href="{{ siteSettings and siteSettings.linkedinUrl ? siteSettings.linkedinUrl : '#' }}" target="_blank" aria-label="LinkedIn">
                        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                        </svg>
                    </a>

                    <a href="mailto:{{ siteSettings and siteSettings.contactEmail ? siteSettings.contactEmail : 'maher@example.com' }}" aria-label="Email">
                        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="2" y="4" width="20" height="16" rx="2"/>
                            <polyline points="2,4 12,13 22,4"/>
                        </svg>
                    </a>
                </div>

            </div>{# fin hero-left #}

            {# DROITE : image portfolio premium #}
<div class="hero-right hero-right--portfolio">
    <div class="portfolio-visual">
        <div class="portfolio-visual-bg"></div>
        <div class="portfolio-visual-ring ring-1"></div>
        <div class="portfolio-visual-ring ring-2"></div>

        <div class="portfolio-photo-card">

            <img
                src="{{ asset('images/me.png') }}"
                alt="Maher Baldi"
                class="portfolio-photo"
            >

            <div class="photo-overlay-gradient"></div>

            <div class="photo-meta">
                <div class="photo-meta-status">
                    <span class="status-dot"></span>
                    Available for work
                </div>
                <h3>Maher Baldi</h3>
            </div>
        </div>
    </div>
</div>

        </div>

        <div class="hero-watermark">MAHER</div>
        <div class="hero-glow glow-1"></div>
        <div class="hero-glow glow-2"></div>

        <div class="scroll-indicator">
            <span>SCROLL</span>
            <i></i>
        </div>
    </section>

    <!-- ABOUT -->
    <section id="about" class="about-section">
        <div class="container about-wrapper">

            <div class="about-top">
                <div class="about-left-intro">
                    <p class="section-label">ABOUT ME</p>
                    <h2 class="about-title">
                        Crafting digital
                        <span>experiences</span>
                        from Tunisia.
                    </h2>
                </div>
                <div class="about-right-intro">
                    <p>
                        I'm a software developer from <strong>Tunisia</strong> with hands-on experience building
                        full-stack web applications. My expertise spans backend systems with Symfony,
                        dynamic frontends with Angular, and enterprise ERP customization with Odoo.
                    </p>
                    <p>
                        I'm passionate about writing clean, maintainable code and delivering high-performance
                        applications. Whether it's an e-commerce platform, a clinic booking system,
                        or a custom ERP module — I focus on scalability, security, and user experience.
                    </p>
                </div>
            </div>

            <div class="about-content-grid">

                <div class="about-left-column">
                    <div class="about-image-card">
                        <img src="{{ asset('images/image_portfilo1.png') }}" alt="Maher Baldi workspace">
                    </div>
                    <div class="stats-grid">
                        <div class="stat-card"><h3>3+</h3><p>YEARS EXPERIENCE</p></div>
                        <div class="stat-card"><h3>10+</h3><p>PROJECTS SHIPPED</p></div>
                        <div class="stat-card"><h3>3</h3><p>CORE FRAMEWORKS</p></div>
                        <div class="stat-card"><h3>100%</h3><p>REMOTE READY</p></div>
                    </div>
                </div>

                <div class="about-right-column" id="skills">
                    <h3 class="skills-title">Technical Skills</h3>
                    <div class="skills-columns">

                        <div class="skills-group">
                            <h4>FRONTEND</h4>
                            {% for skill in frontendSkills %}
                                {% if skill.level is not null %}
                                    <div class="skill-row">
                                        <div class="skill-circle">{{ skill.level }}</div>
                                        <div class="skill-info">
                                            <span class="skill-name">{{ skill.name }}</span>
                                            <div class="skill-bar"><div class="skill-fill" style="width:{{ skill.level }}%"></div></div>
                                        </div>
                                    </div>
                                {% endif %}
                            {% endfor %}
                        </div>

                        <div class="skills-group">
                            <h4>BACKEND</h4>
                            {% for skill in backendSkills %}
                                {% if skill.level is not null %}
                                    <div class="skill-row">
                                        <div class="skill-circle">{{ skill.level }}</div>
                                        <div class="skill-info">
                                            <span class="skill-name">{{ skill.name }}</span>
                                            <div class="skill-bar"><div class="skill-fill" style="width:{{ skill.level }}%"></div></div>
                                        </div>
                                    </div>
                                {% endif %}
                            {% endfor %}
                        </div>

                        <div class="skills-group">
                            <h4>DATABASE & TOOLS</h4>
                            {% for skill in databaseToolsSkills %}
                                {% if skill.level is not null %}
                                    <div class="skill-row">
                                        <div class="skill-circle">{{ skill.level }}</div>
                                        <div class="skill-info">
                                            <span class="skill-name">{{ skill.name }}</span>
                                            <div class="skill-bar"><div class="skill-fill" style="width:{{ skill.level }}%"></div></div>
                                        </div>
                                    </div>
                                {% endif %}
                            {% endfor %}
                        </div>

                    </div>

                    <div class="all-tech-block">
                        <h4>ALL TECHNOLOGIES</h4>
                        <div class="tech-tags">
                            {% for skill in allTechnologyTags %}
                                <span>{{ skill.name }}</span>
                            {% endfor %}
                        </div>
                    </div>

                    <div class="about-download">
                        <a href="{{ asset('files/maher-baldi-cv.pdf') }}" class="btn-download-b" download>
                            <span class="btn-download-b__icon">↓</span>
                            DOWNLOAD FULL CV
                        </a>
                    </div>
                </div>

            </div>
        </div>
    </section>

    <!-- PROJECTS -->
    <section id="projects" class="projects-section">
        <div class="container projects-wrapper">

            <div class="projects-top">
                <div class="projects-heading">
                    <p class="section-label">SELECTED PROJECTS</p>
                    <h2 class="projects-title">Things I've <span>shipped</span></h2>
                </div>
                <div class="projects-intro">
                    <p>Real projects built with production-grade code. Each one solving a specific problem.</p>
                </div>
            </div>

            <div class="projects-grid">
                {% if projects_db is defined and projects_db|length > 0 %}
                    {% for project in projects_db %}
                        <article class="project-card">
                            <div class="project-image-wrap">
                                <img src="{{ asset(project.imagePath) }}" alt="{{ project.title }}">
                            </div>
                            <div class="project-content">
                                <h3>{{ project.title }}</h3>
                                <h4>{{ project.shortDescription }}</h4>
                                <p>{{ project.fullDescription }}</p>
                                <div class="project-features">
                                    {% for feature in project.features %}<span>✓ {{ feature }}</span>{% endfor %}
                                </div>
                                <div class="project-stack">
                                    {% for tech in project.technologies %}<span>{{ tech }}</span>{% endfor %}
                                </div>
                            </div>
                            <div class="project-overlay">
                                {% if project.githubUrl %}
                                    <a href="{{ project.githubUrl }}" target="_blank" class="project-github-btn">GitHub</a>
                                {% endif %}
                                {% if project.demoUrl %}
                                    <a href="{{ project.demoUrl }}" target="_blank" class="project-github-btn">Live Demo</a>
                                {% endif %}
                            </div>
                        </article>
                    {% endfor %}
                {% endif %}
            </div>

            <div class="projects-footer-link">
                <a href="https://github.com/maherbaldi969" target="_blank">View all projects on GitHub <span>→</span></a>
            </div>
        </div>
    </section>

    <!-- EXPERIENCE -->
    <section id="experience" class="experience-section">
        <div class="container experience-wrapper">

            <div class="experience-top">
                <div class="experience-heading">
                    <p class="section-label section-label-dark">EXPERIENCE</p>
                    <h2 class="experience-title">Where I've <span>worked</span></h2>
                </div>
                <div class="experience-intro">
                    <p>Real-world experience building production systems for clients across Tunisia.</p>
                </div>
            </div>

            <div class="experience-list">
                {% for item in experiences %}
                    <article class="experience-card {{ item.isFeatured ? 'experience-card-active' : '' }}">
                        <div class="experience-left">
                            <h3>{{ item.jobTitle }}</h3>
                            <h4>{{ item.companyName }}</h4>
                            {% if item.employmentType %}
                                <span class="experience-badge">{{ item.employmentType }}</span>
                            {% endif %}
                            <div class="experience-meta">
                                <p>🗓 {{ item.startLabel }} — {{ item.endLabel }}</p>
                                {% if item.locationLabel %}<p>📍 {{ item.locationLabel }}</p>{% endif %}
                            </div>
                        </div>
                        <div class="experience-right">
                            <p class="experience-summary">{{ item.summary }}</p>
                            <ul class="experience-points">
                                {% for point in item.achievements %}<li>{{ point }}</li>{% endfor %}
                            </ul>
                            <div class="experience-stack">
                                {% for tech in item.technologies %}<span>{{ tech }}</span>{% endfor %}
                            </div>
                        </div>
                    </article>
                {% endfor %}

                {% for education in educations %}
                    <article class="education-card">
                        <div class="education-icon"><span>✦</span></div>
                        <div class="education-content">
                            <h3>{{ education.degreeTitle }}</h3>
                            <p>{{ education.schoolName }}{% if education.graduationLabel %} · {{ education.graduationLabel }}{% endif %}</p>
                        </div>
                    </article>
                {% endfor %}
            </div>
        </div>
    </section>

    <!-- CONTACT -->
    <section id="contact" class="contact-section">
        <div class="container contact-wrapper">

            {% for message in app.flashes('success') %}
                <div class="contact-success-message">{{ message }}</div>
            {% endfor %}

            <div class="contact-heading">
                <p class="section-label">GET IN TOUCH</p>
                <h2 class="contact-title">Let's work <span>together</span></h2>
                <p class="contact-subtitle">
                    Have a project in mind or looking for a developer? I'm open to freelance
                    work and full-time opportunities.
                </p>
            </div>

            <div class="contact-grid">

                <div class="contact-left">
                    <div class="contact-info-list">

                        <div class="contact-info-item">
                            <div class="contact-icon-box">
                                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M20 10c0 6-8 12-8 12S4 16 4 10a8 8 0 1 1 16 0Z"/><circle cx="12" cy="10" r="3"/>
                                </svg>
                            </div>
                            <div><h4>LOCATION</h4><p>Tunisia</p></div>
                        </div>

                        <a href="mailto:maherbaaldi@gmail.com" class="contact-info-item">
                            <div class="contact-icon-box">
                                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
                                </svg>
                            </div>
                            <div><h4>EMAIL</h4><p>maherbaaldi@gmail.com</p></div>
                        </a>

                        <a href="https://linkedin.com/in/maherbaldi" target="_blank" rel="noopener noreferrer" class="contact-info-item">
                            <div class="contact-icon-box">
                                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                                    <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
                                    <rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/>
                                </svg>
                            </div>
                            <div><h4>LINKEDIN</h4><p>www.linkedin.com/in/maherbaldi</p></div>
                        </a>

                        <a href="https://github.com/maherbaldi969" target="_blank" rel="noopener noreferrer" class="contact-info-item">
                            <div class="contact-icon-box">
                                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                                    <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/>
                                    <path d="M9 18c-4.51 2-5-2-7-2"/>
                                </svg>
                            </div>
                            <div><h4>GITHUB</h4><p>https://github.com/maherbaldi969</p></div>
                        </a>
                    </div>

                    <div class="availability-card">
                        <div class="availability-head">
                            <span class="availability-dot"></span>
                            <h3>Currently Available</h3>
                        </div>
                        <p>I'm actively looking for new opportunities — full-time roles and freelance projects. Response time: usually within 24 hours.</p>
                        <div class="availability-tags">
                            <span>Full-time</span>
                            <span>Freelance</span>
                            <span>Remote</span>
                            <span>On-site (Tunisia)</span>
                        </div>
                    </div>
                </div>

                <div class="contact-right">
                    {{ form_start(contactForm, {'attr': {'class': 'contact-form'}}) }}

                        <div class="contact-form-row">
                            <div class="form-group">
                                {{ form_label(contactForm.fullName, 'NAME') }}
                                {{ form_widget(contactForm.fullName, {'attr': {'placeholder': 'Your full name'}}) }}
                                {{ form_errors(contactForm.fullName) }}
                            </div>
                            <div class="form-group">
                                {{ form_label(contactForm.email, 'EMAIL') }}
                                {{ form_widget(contactForm.email, {'attr': {'placeholder': 'your@email.com'}}) }}
                                {{ form_errors(contactForm.email) }}
                            </div>
                        </div>

                        <div class="form-group">
                            {{ form_label(contactForm.subject, 'SUBJECT') }}
                            {{ form_widget(contactForm.subject, {'attr': {'placeholder': 'Project, freelance, full-time...'}}) }}
                            {{ form_errors(contactForm.subject) }}
                        </div>

                        <div class="form-group">
                            {{ form_label(contactForm.message, 'MESSAGE') }}
                            {{ form_widget(contactForm.message, {'attr': {'rows': 6, 'placeholder': 'Tell me about your project or opportunity...'}}) }}
                            {{ form_errors(contactForm.message) }}
                        </div>

                        <button type="submit" class="contact-submit-btn">
                            <span>✈</span> SEND MESSAGE
                        </button>

                        <p class="contact-direct-email">
                            Or email me directly at
                            <a href="mailto:maherbaldi.dev@gmail.com">maherbaldi.dev@gmail.com</a>
                        </p>

                    {{ form_end(contactForm) }}
                </div>

            </div>
        </div>
    </section>

    <!-- FOOTER -->
   <!-- FOOTER -->
<footer class="site-footer">
    <div class="container footer-main">

        <div class="footer-brand">
            <a href="{{ path('app_home') }}" class="brand footer-brand-link">

                <!-- LOGO IMAGE -->
                <span class="brand-logo">
                    <img src="{{ asset('images/Background (2).png') }}" alt="MB Logo" class="brand-img">
                </span>

                <span class="brand-text">MB<span class="dot">.</span></span>
            </a>

            <p>Building modern and scalable web applications.</p>

            <!-- ICONS RÉELS -->
            <div class="footer-socials">
                <a href="https://github.com/maherbaldi969" target="_blank" aria-label="GitHub">
                    <i class="fab fa-github"></i>
                </a>

                <a href="https://linkedin.com/in/maherbaldi" target="_blank" aria-label="LinkedIn">
                    <i class="fab fa-linkedin-in"></i>
                </a>

                <a href="mailto:maherbaaldi@gmail.com" aria-label="Email">
                    <i class="fas fa-envelope"></i>
                </a>
            </div>
        </div>

        <div class="footer-bottom">
            <p>© 2026 Maher Baldi. All rights reserved.</p>

            <div class="footer-links">
                <a href="#">Privacy</a>
                <a href="#">Terms</a>
            </div>
        </div>

    </div>
</footer>

</div>
{% endblock %}
