{% extends 'base.html.twig' %}

{% block title %}Maher Baldi | Portfolio{% endblock %}

{% block body %}
<div class="portfolio-page">

    <!-- HEADER -->
    <header class="site-header">
        <div class="container header-inner">
            <a href="#" class="brand">
                <span class="brand-logo">
                    <span class="brand-mark"></span>
                </span>
                <span class="brand-text">MB<span class="dot">.</span></span>
            </a>

            <nav class="desktop-nav">
                <a href="#about">About</a>
                <a href="#skills">Skills</a>
                <a href="#projects">Projects</a>
                <a href="#experience">Experience</a>
                <a href="#contact">Contact</a>
            </nav>

            <a href="{{ asset('files/maher-baldi-cv.pdf') }}" class="btn btn-primary header-btn" download>
                DOWNLOAD CV
            </a>
        </div>
    </header>

    <!-- HERO -->
    <section class="hero-section">
        <div class="container hero-grid">

            <div class="hero-left">
                <p class="availability">AVAILABLE FOR HIRE · TUNISIA</p>

                <h1 class="hero-title">
                    <span class="first-name">Maher</span>
                    <span class="last-name">Baldi</span>
                </h1>

                <div class="hero-role">
                    <span>Full Stack Developer</span>
                    <span class="separator">·</span>
                    <span>Symfony</span>
                    <span class="separator">·</span>
                    <span>Angular</span>
                    <span class="separator">·</span>
                    <span>Odoo</span>
                </div>

                <p class="hero-description">
                    Passionate software developer specializing in modern web applications using Symfony,
                    Angular, and Odoo. I build scalable, secure, and high-performance systems.
                </p>

                <div class="hero-actions">
                    <a href="#projects" class="btn btn-primary btn-large">
                        <span class="icon">⌘</span>
                        VIEW PROJECTS
                    </a>
                    <a href="{{ asset('files/maher-baldi-cv.pdf') }}" class="btn btn-outline btn-large" download>
                        <span class="icon">↓</span>
                        DOWNLOAD CV
                    </a>
                </div>

                <div class="hero-secondary">
                    <a href="#contact" class="btn btn-outline contact-btn">
                        <span class="icon">✉</span>
                        CONTACT ME
                    </a>
                </div>

                <div class="social-row">
                    <span class="line"></span>
                    <a href="https://github.com/" target="_blank">GitHub</a>
                    <a href="https://linkedin.com/" target="_blank">LinkedIn</a>
                    <a href="mailto:maher@example.com">Email</a>
                </div>
            </div>

            <div class="hero-right">
                <div class="terminal-card">
                    <div class="terminal-top">
                        <div class="terminal-dots">
                            <span class="dot red"></span>
                            <span class="dot yellow"></span>
                            <span class="dot green"></span>
                        </div>
                        <div class="terminal-title">maher@portfolio:~</div>
                    </div>
                    <div class="terminal-body">
                        <div class="terminal-line">
                            <span class="prompt">❯ ~</span>
                            <span class="command">whoami</span>
                        </div>
                        <div class="terminal-output">Maher Baldi</div>

                        <div class="terminal-line">
                            <span class="prompt">❯ ~</span>
                            <span class="command">cat skills.txt</span>
                        </div>
                        <div class="terminal-output">Symfony · Angular · Odoo · PHP · MySQL</div>

                        <div class="terminal-line">
                            <span class="prompt">❯ ~</span>
                            <span class="command">echo $STATUS</span>
                        </div>
                        <div class="terminal-output">Available for new opportunities ✓</div>

                        <div class="terminal-tags">
                            <span>symfony</span>
                            <span>angular</span>
                            <span>odoo</span>
                            <span>php</span>
                            <span>mysql</span>
                        </div>
                    </div>
                </div>

                <div class="status-badge">
                    <span class="status-dot"></span>
                    Open to full-time &amp; freelance roles
                </div>
            </div>
        </div>

        <div class="hero-watermark">MAHER</div>
        <div class="hero-glow glow-1"></div>
        <div class="hero-glow glow-2"></div>

        <div class="scroll-indicator">
            <span>SCROLL</span>
            <i></i>
        </div>
    </section>

    {# ── SECTIONS INCLUSES ── #}
    {% include 'home/about.html.twig' %}
    {% include 'home/projects.html.twig' %}
    {% include 'home/experience.html.twig' %}
    {% include 'home/contact.html.twig' %}

    <!-- FOOTER -->
    <footer class="site-footer">
        <div class="container footer-main">
            <div class="footer-brand">
                <a href="#" class="brand footer-brand-link">
                    <span class="brand-logo">
                        <span class="brand-mark"></span>
                    </span>
                    <span class="brand-text">MB<span class="dot">.</span></span>
                </a>
                <p>Building modern and scalable web applications.</p>
                <div class="footer-socials">
                    <a href="https://github.com/" target="_blank" aria-label="GitHub">⌘</a>
                    <a href="https://linkedin.com/" target="_blank" aria-label="LinkedIn">in</a>
                    <a href="mailto:maherbaldi.dev@gmail.com" aria-label="Email">✉</a>
                </div>
            </div>
            <div class="footer-bottom">
                <p>© 2026 Maher Baldi. All rights reserved.</p>
                <div class="footer-links">
                    <a href="#">Privacy</a>
                    <a href="#">Terms</a>
                </div>
            </div>
        </div>
    </footer>

</div>
{% endblock %}
